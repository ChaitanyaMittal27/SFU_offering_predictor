# ============================================================
# SFU Course Predictor — .gitignore
# ============================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Environment
venv/
.venv/
env/
.env

# Jupyter
.jupyter/
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Streamlit
.streamlit/secrets.toml

# Local resources
local_resources/

# Test outputs
src/tests/coursys_api/output/
src/tests/verify_db/verify_db_output.txt

# Logs
data/raw/collection_log.txt

# Data — large/regenerable, not for portfolio repo
data/raw/sfu_ml.db
data/processed/

# Models — large binaries, not for portfolio repo
models/

# Scratch
dir.txt